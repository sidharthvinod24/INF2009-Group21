# Pi 1 Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Telegram ────────────────────────────────────────────────────────────────
# Get a bot token from @BotFather on Telegram: https://t.me/BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# The chat ID (or group ID) that should receive alerts and bot commands.
# To find your chat ID: send a message to your bot, then visit
#   https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Model ────────────────────────────────────────────────────────────────────
# Absolute path to the YOLO26n-pose ONNX model file.
# The model is NOT included in this repository — obtain it from your team.
MODEL_PATH=/home/pi/INF2009-Group21/pi1/models/yolo26n-pose.onnx

# ── Camera ───────────────────────────────────────────────────────────────────
# USB camera device index. 0 = first USB camera. Try 1 or 2 if 0 doesn't work.
CAMERA_INDEX=0

# ── Web Server ───────────────────────────────────────────────────────────────
# Port for the Flask web dashboard and MJPEG stream.
WEB_PORT=5001
