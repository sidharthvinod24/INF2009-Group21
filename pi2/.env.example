# Pi 2 Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Telegram ────────────────────────────────────────────────────────────────
# Use the same bot token and chat ID as Pi 1.
# Get a bot token from @BotFather on Telegram: https://t.me/BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# The same chat ID used for Pi 1 — both Pis send to the same chat.
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Model ────────────────────────────────────────────────────────────────────
# Absolute path to the YOLO26n-pose ONNX model file.
# The model is NOT included in this repository — obtain it from your team.
MODEL_PATH=/home/pi/INF2009-Group21/pi2/models/yolo26n-pose.onnx

# ── Camera ───────────────────────────────────────────────────────────────────
# USB camera device index. 0 = first USB camera.
CAMERA_INDEX=0

# ── Web Server ───────────────────────────────────────────────────────────────
# Port for the Flask web dashboard and MJPEG stream.
WEB_PORT=5000

# ── Cross-Camera Watchdog ────────────────────────────────────────────────────
# URL of Pi 1's /person_status endpoint. Used by the child watchdog thread.
# Replace <pi1-ip> with Pi 1's static IP address or hostname.
PI1_STATUS_URL=http://<pi1-ip>:5001/person_status

# ── PIR Sensor ───────────────────────────────────────────────────────────────
# Set to "false" to disable PIR and run the camera continuously (e.g., for testing).
ENABLE_PIR=true
